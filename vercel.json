{
  "rewrites": [
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/app/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/",
      "destination": "/landing.html"
    },
    {
      "source": "/((?!index.html|assets|logo.png|og.png|landing.html|shop.html|youtube.html|worry.html).*)",
      "destination": "/index.html"
    }
  ]
}
